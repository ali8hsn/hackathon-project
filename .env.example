# Anthropic — used by ARIA (/intake) and Sentinel AI (incidents, reports, triage)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — ElevenLabs TTS on /intake (if set, key is sent to the browser for API calls; keep app local/private)
# ELEVENLABS_API_KEY=
# Optional — same voice for Twilio phone TTS (server-side); defaults to Sarah voice id if unset
# ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Public URL of this app (required for Twilio webhooks & <Play> audio). No trailing slash.
# Example ngrok: PUBLIC_BASE_URL=https://abc123.ngrok-free.app
# PUBLIC_BASE_URL=

# Only if the browser UI is hosted on a *different* origin than this Node server (split deploy):
# set this so /dispatch-live connects WebSocket + API to the Siren host. Same as PUBLIC_BASE_URL if one server.
# NEXT_PUBLIC_ARIA_ORIGIN=https://your-siren-server.example.com

# Optional: lock CORS to your frontend origin instead of * (default). Example:
# ARIA_CORS_ORIGIN=https://your-frontend.example.com

# Twilio — phone calls → Siren (configure number Voice webhook POST to /api/aria/twilio/voice)
# Optional signature validation (recommended in production):
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# Also set Status callback URL on the number to POST /api/aria/twilio/call-status when call ends

# MongoDB — incidents, transcripts, Sentinel monitor (Atlas or self-hosted)
MONGODB_URI=mongodb://127.0.0.1:27017
# Optional database name (default: sentinel)
# MONGODB_DB_NAME=sentinel

# Server (unified ARIA + Next)
PORT=3000

# ─── AWS (optional but recommended on EC2/ECS — Twilio TTS audio via S3 presigned URLs) ───
# Standard SDK env vars (export in shell or paste here). IAM roles on EC2/ECS: omit keys.
# AWS_DEFAULT_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=   # only for temporary credentials (SSO / assumed role)
# Bucket for ElevenLabs MP3s for phone playback (PutObject + presigned Get). Create bucket in same region.
# AWS_S3_TWILIO_BUCKET=your-bucket-name
# Optional key prefix inside bucket (default: twilio-audio)
# AWS_S3_PREFIX=twilio-audio
# Optional presigned URL lifetime in seconds (default 3600)
# AWS_S3_PRESIGN_SECONDS=3600
# Do NOT put SSH .pem private keys here — those are for SSH into EC2, not for this app.
