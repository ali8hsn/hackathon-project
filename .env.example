# Anthropic — used by ARIA (/intake) and Haashir AI (incidents, reports, triage)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Gemini — used by Haashir for 1-10 severity scoring on incoming calls
GEMINI_API_KEY=

# Optional — ElevenLabs TTS on /intake (if set, key is sent to the browser for API calls; keep app local/private)
# ELEVENLABS_API_KEY=

# MongoDB — incidents, transcripts, Haashir monitor (Atlas or self-hosted)
MONGODB_URI=mongodb://127.0.0.1:27017
# Optional database name (default: sentinel — kept for backward-compat with existing data)
# MONGODB_DB_NAME=sentinel

# Server (unified ARIA + Next)
PORT=3000

# Optional: Twilio voice webhooks (recording still needs a separate STT provider for phone audio)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
